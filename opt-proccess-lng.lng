! TP IO 2026
INTEGRANTES: ALAGUIBE, MUÑOZ, POZZO, ZEBALLOS
PROBLEMA: Costos de transporte y proyección del índice inflacionario
;
Model:

SETS:
PLANTA:
	CAPACIDAD_LECHE_FLUIDA,
	CAPACIDAD_LECHE_EN_POLVO,
	CAPACIDAD_CREMA,
	CAPACIDAD_MANTECA,
	CAPACIDAD_QUESO,
	Y;					!VARIABLE DE DECISION;

CENTROS;

PRODUCTOS:
	FACTOR_CONVERSION;

DEMANDA(PRODUCTOS, CENTROS):
	DEM;

ENVIO(PRODUCTOS, PLANTA, CENTROS):	
	COSTO,				
	X;					!VARIABLE DE DECISION (cantidad);

DESCREMA(PLANTA):
	COSTO_LD_SF,
	LECHE_DESCREMADA_SF;		!VARIABLE DE DECISION;

ENDSETS

! IMPORTACION DESDE EXCEL;

DATA:
	PLANTA, CENTROS, PRODUCTOS, DESCREMA,
  	FACTOR_CONVERSION,
  	CAPACIDAD_LECHE_FLUIDA, CAPACIDAD_LECHE_EN_POLVO,
	CAPACIDAD_CREMA, CAPACIDAD_MANTECA, CAPACIDAD_QUESO,COSTO_LD_SF,
  	COSTO,
  	DEM
	=
	@OLE('DATASOURCE.xlsx',
    		'PLANTA', 'CENTROS', 'PRODUCTOS', 'DESCREMA',
    		'FACTOR_CONVERSION',
    		'CAPACIDAD_LECHE_FLUIDA', 'CAPACIDAD_LECHE_EN_POLVO',
    		'CAPACIDAD_CREMA', 'CAPACIDAD_MANTECA', 'CAPACIDAD_QUESO',
    		'COSTO_LD_SF',
    		'COSTO',
    		'DEM'
  	);

LECHE_DISPONIBLE = 24800000;

ENDDATA

!FUNCION OBJETIVO;
[FO] MIN=@SUM(ENVIO(I, J, K): COSTO(I,J,K) * X(I,J,K)) + @SUM(DESCREMA(J): COSTO_LD_SF(J) * LECHE_DESCREMADA_SF(J));

@FOR(DESCREMA(J): [LP_BA_C]
	@SUM(CENTROS(K):
		FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFE'))*X(@INDEX(PRODUCTOS,'LFE'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LPD'))*X(@INDEX(PRODUCTOS,'LPD'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LPE'))*X(@INDEX(PRODUCTOS,'LPE'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*X(@INDEX(PRODUCTOS,'LFD'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'QB'))*X(@INDEX(PRODUCTOS,'QB'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'QMB'))*X(@INDEX(PRODUCTOS,'QMB'),J,K)
	)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*LECHE_DESCREMADA_SF(J)
		- Y(J)
		= 0
);

[LE_SF]
@SUM(CENTROS(K):
	FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFE'))*X(@INDEX(PRODUCTOS,'LFE'),@INDEX(PLANTA,'P3'),K)
	+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LPE'))*X(@INDEX(PRODUCTOS,'LPE'),@INDEX(PLANTA,'P3'),K)
	+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'QB'))*X(@INDEX(PRODUCTOS,'QB'), @INDEX(PLANTA,'P3'),K)
	+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'QMB'))*X(@INDEX(PRODUCTOS,'QMB'),@INDEX(PLANTA,'P3'),K)
)
= Y(@INDEX(PLANTA,'P3'));

[LD_SF]
@SUM(DESCREMA(J):
	FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*LECHE_DESCREMADA_SF(J))
=
@SUM(CENTROS(K):
	FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LPD'))*X(@INDEX(PRODUCTOS,'LPD'),@INDEX(PLANTA,'P3'),K)
	+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*X(@INDEX(PRODUCTOS,'LFD'),@INDEX(PLANTA,'P3'),K)
);

@FOR(DESCREMA(J): [CREMA_MANTECA_NO_DESPERDICIOS]
	@SUM(CENTROS(K):
		FACTOR_CONVERSION(@INDEX(PRODUCTOS,'CREMA'))*X(@INDEX(PRODUCTOS,'CREMA'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'MANTECA'))*X(@INDEX(PRODUCTOS,'MANTECA'),J,K)
	)
	=
	FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*LECHE_DESCREMADA_SF(J)
	+ @SUM(CENTROS(K):
		FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LPD'))*X(@INDEX(PRODUCTOS,'LPD'),J,K)
		+ FACTOR_CONVERSION(@INDEX(PRODUCTOS,'LFD'))*X(@INDEX(PRODUCTOS,'LFD'),J,K)
	)
);

! RESTRICCION DE DISPONIBILIDAD DE MATERIA PRIMA ;
[DISPONIBILIDAD_DE_LECHE]
@SUM(PLANTA(J):Y(J)) <= 0.98 * LECHE_DISPONIBLE;

! RESTRICCION DE SATISFACCION DE DEMANDA ;
@FOR(DEMANDA(I,K): [SATISFACER_DEMANDA]
	@SUM(PLANTA(J):X(I,J,K)) >= DEM(I,K)
);	

! RESTRICCIONES DE CAPACIDAD ;
[CAPACIDAD_LECHE_FLUIDA_1]
@SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'LFE'),@INDEX(PLANTA,'P3'),K)) <= CAPACIDAD_LECHE_FLUIDA(@INDEX(PLANTA,'P3'));

@FOR(DESCREMA(J): [CAPACIDAD_LECHE_FLUIDA_2]
	@SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'LFE'),J,K)) + @SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'LFD'),J,K)) + LECHE_DESCREMADA_SF(J)
	<= CAPACIDAD_LECHE_FLUIDA(J));

@FOR(DESCREMA(J): [R_CAPACIDAD_CREMA] @SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'CREMA'),J,K)) <= CAPACIDAD_CREMA(J));

@FOR(DESCREMA(J): [R_CAPACIDAD_MANTECA] @SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'MANTECA'),J,K)) <= CAPACIDAD_MANTECA(J));

@FOR(PLANTA(J): [R_CAPACIDAD_LECHE_EN_POLVO] @SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'LPE'),J,K) + X(@INDEX(PRODUCTOS,'LPD'),J,K)) <= CAPACIDAD_LECHE_EN_POLVO(J));

@FOR(PLANTA(J): [R_CAPACIDAD_QUESO] @SUM(CENTROS(K): X(@INDEX(PRODUCTOS,'QB'),J,K) + X(@INDEX(PRODUCTOS,'QMB'),J,K)) <= CAPACIDAD_QUESO(J));

END
